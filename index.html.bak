// ── IMAGES ──
const CLARO_IMG = `data:image/svg+xml;base64,`;

// ── HELPERS ──
const DAYS_ES = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
const TODAY = '10/05/2026';

function parseDate(str){ const [d,m,y]=str.split('/'); return new Date(+y,+m-1,+d); }
function dowLabel(str){ const d=parseDate(str); return DAYS_ES[d.getDay()]; }
function shortDate(str){ const [d,m]=str.split('/'); return `${d}/${m}`; }
function initials(name){ return name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase(); }
function getPersonData(name){ return DATA.filter(r=>r.nombre===name).sort((a,b)=>parseDate(a.fecha)-parseDate(b.fecha)); }
function getByDate(name,fecha){ return DATA.find(r=>r.nombre===name&&r.fecha===fecha); }
const allNames = [...new Set(DATA.map(r=>r.nombre))].sort();
const allDates = [...new Set(DATA.map(r=>r.fecha))].sort((a,b)=>parseDate(a)-parseDate(b));
const todayData = DATA.filter(r=>r.fecha===TODAY);

// ── AUTH SYSTEM ──
const STORAGE_KEY = 'tb_users_v1';
const SESSION_KEY = 'tb_session_v1';

function getUsers(){ try{ return JSON.parse(localStorage.getItem(STORAGE_KEY)||'{}'); }catch(e){ return {}; } }
function saveUsers(u){ localStorage.setItem(STORAGE_KEY, JSON.stringify(u)); }
function getSession(){ try{ return JSON.parse(sessionStorage.getItem(SESSION_KEY)||'null'); }catch(e){ return null; } }
function saveSession(s){ sessionStorage.setItem(SESSION_KEY, JSON.stringify(s)); }
function clearSession(){ sessionStorage.removeItem(SESSION_KEY); }

function normalizeName(n){ return n.trim().toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g,''); }

function loginMoi(){
  const pin = prompt('🔐 PIN de administrador:');
  if(pin !== '1999'){ alert('❌ PIN incorrecto'); return; }
  const users = getUsers();
  saveSession({ nombre: 'MOISES ROJAS', esMoises: true });
  document.getElementById('loading-overlay').style.display='none';
  document.querySelectorAll('.screen').forEach(s=>{ s.classList.remove('active'); s.style.display='none'; });
  var s = document.getElementById('screen-home');
  if(s){ s.style.display='block'; s.classList.add('active'); }
  initHome();
}
function doLogin(){
  const nombre = document.getElementById('login-nombre').value.trim().toUpperCase();
  const pass = document.getElementById('login-pass').value;
  const errEl = document.getElementById('login-error');
  errEl.style.display = 'none';
  if(!nombre || !pass){ errEl.textContent='❌ Completa todos los campos'; errEl.style.display='block'; return; }
  // Match name against DATA
  const nameNorm = normalizeName(nombre);
  const match = allNames.find(n => normalizeName(n).includes(nameNorm) || nameNorm.includes(normalizeName(n)));
  if(!match){ errEl.textContent='❌ Tu nombre no está en la maya actual'; errEl.style.display='block'; return; }
  const users = getUsers();
  if(!users[match]){ errEl.textContent='❌ No tienes cuenta. Regístrate primero'; errEl.style.display='block'; return; }
  // Simple hash check
  if(users[match] !== btoa(pass)){ errEl.textContent='❌ Contraseña incorrecta'; errEl.style.display='block'; return; }
  saveSession({ nombre: match });
  showScreen('screen-home');
  initHome();
}

let regFotoB64 = null;
function previewRegFoto(input){
  const file = input.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    regFotoB64 = e.target.result;
    const prev = document.getElementById('reg-foto-prev');
    prev.innerHTML = `<img src="${regFotoB64}" alt="foto">`;
  };
  reader.readAsDataURL(file);
}

function doRegister(){
  const nombre = document.getElementById('reg-nombre').value.trim().toUpperCase();
  const nombreCompleto = document.getElementById('reg-nombre-completo').value.trim();
  const celular = document.getElementById('reg-celular').value.trim();
  const correo = document.getElementById('reg-correo').value.trim();
  const pass = document.getElementById('reg-pass').value;
  const pass2 = document.getElementById('reg-pass2').value;
  const errEl = document.getElementById('reg-error');
  errEl.style.display = 'none'; errEl.style.color = 'var(--red)';
  if(!regFotoB64){ errEl.textContent='❌ Sube tu foto (es obligatoria)'; errEl.style.display='block'; return; }
  if(!nombre||!pass){ errEl.textContent='❌ Completa todos los campos'; errEl.style.display='block'; return; }
  if(!nombreCompleto){ errEl.textContent='❌ Ingresa tu nombre completo'; errEl.style.display='block'; return; }
  if(!celular){ errEl.textContent='❌ El celular es obligatorio'; errEl.style.display='block'; return; }
  if(!correo || !correo.includes('@')){ errEl.textContent='❌ Ingresa un correo válido'; errEl.style.display='block'; return; }
  if(pass.length < 4){ errEl.textContent='❌ Mínimo 4 caracteres'; errEl.style.display='block'; return; }
  if(pass !== pass2){ errEl.textContent='❌ Las contraseñas no coinciden'; errEl.style.display='block'; return; }
  const nameNorm = normalizeName(nombre);
  const match = allNames.find(n => normalizeName(n).includes(nameNorm) || nameNorm.includes(normalizeName(n)));
  if(!match){ errEl.textContent='❌ Nombre no encontrado en la maya. Escríbelo tal como aparece'; errEl.style.display='block'; return; }
  const users = getUsers();
  // Guardar en localStorage (local) + enviar al backend si está disponible
  users[match] = { hash: btoa(pass), foto: regFotoB64, nombreCompleto, celular, correo };
  saveUsers(users);
  // Intentar sincronizar con backend
  fetch(BACKEND+'/registrar', { method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ nombre: match, password: btoa(pass), foto: regFotoB64, nombreCompleto, celular, correo })
  }).catch(()=>{});
  errEl.textContent=`✅ Cuenta creada para ${match.split(' ').slice(0,2).join(' ')}`;
  errEl.style.color='var(--grn)'; errEl.style.display='block';
  setTimeout(()=>{ document.getElementById('loading-overlay').style.display='none'; showLogin(); document.getElementById('login-nombre').value=match; },1500);
}

function showRegister(){ document.getElementById('login-card').style.display='none'; document.getElementById('register-card').style.display='block'; }
function showLogin(){ document.getElementById('register-card').style.display='none'; document.getElementById('login-card').style.display='block'; }
function showRecover(){ document.getElementById('modal-recover').style.display='flex'; document.getElementById('recover-step1').style.display='block'; document.getElementById('recover-step2').style.display='none'; }

// ── SPLASH ──
function getSaludoHora(){
  const h = new Date().getHours();
  if(h>=5&&h<12) return ['🌅 ¡Buenos días!','☀️'];
  if(h>=12&&h<18) return ['☀️ ¡Buenas tardes!','🌤️'];
  return ['🌙 ¡Buenas noches!','🌙'];
}
function mostrarSplash(session){
  const sp = document.getElementById('splash-screen');
  if(!sp) return;
  const [saludo] = getSaludoHora();
  document.getElementById('splash-greeting').textContent = saludo;
  if(session && session.esMoises){
    document.getElementById('splash-greeting').textContent = getSaludoHora()[0];
    document.getElementById('splash-uname').innerHTML = '<span class="fire-name">🔥 Moisés Rojas 🔥</span>';
    document.getElementById('splash-av').textContent = '🔥';
    document.getElementById('splash-av').style.cssText='width:90px;height:90px;border-radius:50%;border:3px solid #ff6a00;background:linear-gradient(135deg,#ff6a00,#ffd700);display:flex;align-items:center;justify-content:center;font-size:44px;box-shadow:0 0 32px rgba(255,106,0,.8);animation:pulse 2s infinite';
  } else if(session && session.nombre){
    const firstName = session.nombre.split(' ').slice(-1)[0]; // apellido primero → tomar último token como nombre
    document.getElementById('splash-uname').textContent = session.nombre.split(' ').slice(0,2).join(' ');
    // Intentar cargar foto desde localStorage
    const users = getUsers();
    const u = users[session.nombre];
    const foto = (u && u.foto) ? u.foto : null;
    if(foto){
      document.getElementById('splash-av').outerHTML = `<img id="splash-av" class="splash-avatar" src="${foto}" alt="foto">`;
    } else {
      // Emoji según género heurístico: si el nombre termina en 'a' → femenino
      const emoji = (session.nombre.split(' ')[1]||'').toLowerCase().endsWith('a') ? '👩' : '👨';
      document.getElementById('splash-av').textContent = emoji;
    }
  } else {
    document.getElementById('splash-greeting').textContent = getSaludoHora()[0];
    document.getElementById('splash-uname').textContent = 'Millennium BPO';
  }
  sp.classList.remove('hidden');
  setTimeout(()=>{ sp.classList.add('hidden'); setTimeout(()=>{ sp.style.display='none'; },700); }, 2500);
}

// ── CAMBIO DE CONTRASEÑA ──
function abrirCambiarPass(){ document.getElementById('modal-cambiar-pass').style.display='flex'; }
function doCambiarPass(){
  const session = getSession(); if(!session) return;
  const actual = document.getElementById('cp-actual').value;
  const nueva = document.getElementById('cp-nueva').value;
  const nueva2 = document.getElementById('cp-nueva2').value;
  const msg = document.getElementById('cp-msg');
  msg.style.display='block'; msg.style.background='rgba(239,68,68,.1)'; msg.style.color='var(--red)';
  if(!actual||!nueva||!nueva2){ msg.textContent='❌ Completa todos los campos'; return; }
  if(nueva.length<4){ msg.textContent='❌ Mínimo 4 caracteres'; return; }
  if(nueva!==nueva2){ msg.textContent='❌ Las contraseñas no coinciden'; return; }
  const users = getUsers();
  const u = users[session.nombre];
  const hashActual = (u && u.hash) ? u.hash : u;
  if(hashActual !== btoa(actual)){ msg.textContent='❌ Contraseña actual incorrecta'; return; }
  if(u && u.hash) users[session.nombre].hash = btoa(nueva); else users[session.nombre] = btoa(nueva);
  saveUsers(users);
  fetch(BACKEND+'/cambiar-password',{method:'POST',headers:{'Content-Type':'application/json'},
    body: JSON.stringify({nombre: session.nombre, passwordActual: hashActual, nuevaPassword: btoa(nueva)})}).catch(()=>{});
  msg.style.background='rgba(16,185,129,.1)'; msg.style.color='var(--grn)';
  msg.textContent='✅ Contraseña cambiada exitosamente';
  setTimeout(()=>{ document.getElementById('modal-cambiar-pass').style.display='none'; },2000);
}

// ── RECUPERAR CONTRASEÑA ──
let _recNombre = '';
function doSolicitarToken(){
  const nombre = document.getElementById('rec-nombre').value.trim().toUpperCase();
  const msg = document.getElementById('rec-msg1');
  msg.style.display='block'; msg.style.background='rgba(239,68,68,.1)'; msg.style.color='var(--red)';
  if(!nombre){ msg.textContent='❌ Ingresa tu nombre'; return; }
  _recNombre = nombre;
  // Intentar por backend
  fetch(BACKEND+'/solicitar-token',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({nombre})})
  .then(r=>r.json()).then(d=>{
    if(d.ok){ msg.style.background='rgba(16,185,129,.1)'; msg.style.color='var(--grn)'; msg.textContent='📨 '+d.mensaje;
      setTimeout(()=>{ document.getElementById('recover-step1').style.display='none'; document.getElementById('recover-step2').style.display='block'; },1500);
    } else { msg.textContent='❌ '+(d.error||'Error al solicitar token'); }
  }).catch(()=>{ msg.textContent='⚠️ Backend no disponible. Contacta a tu admin para restablecer tu contraseña.'; });
}
function doResetPass(){
  const token = document.getElementById('rec-token').value.trim();
  const nueva = document.getElementById('rec-nueva').value;
  const msg = document.getElementById('rec-msg2');
  msg.style.display='block'; msg.style.background='rgba(239,68,68,.1)'; msg.style.color='var(--red)';
  if(!token||!nueva){ msg.textContent='❌ Completa todos los campos'; return; }
  fetch(BACKEND+'/reset-password',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({nombre:_recNombre,token,nuevaPassword:btoa(nueva)})})
  .then(r=>r.json()).then(d=>{
    if(d.ok){ msg.style.background='rgba(16,185,129,.1)'; msg.style.color='var(--grn)'; msg.textContent='✅ '+d.mensaje;
      const users=getUsers(); if(users[_recNombre]){ if(users[_recNombre].hash) users[_recNombre].hash=btoa(nueva); else users[_recNombre]=btoa(nueva); saveUsers(users); }
      setTimeout(()=>{ document.getElementById('modal-recover').style.display='none'; showLogin(); },2000);
    } else { msg.textContent='❌ '+(d.error||'Error'); }
  }).catch(()=>{ msg.textContent='⚠️ Backend no disponible'; });
}

// El botón de cambiar contraseña se agrega dinámicamente desde initHome, ver abajo
function doLogout(){
  if(!confirm('¿Cerrar sesión?')) return;
  clearSession();
  showScreen('screen-login');
}

// ── NOTIFICATIONS (stored in localStorage from admin sync) ──
const NOTIF_KEY = 'tb_notifications_v1';
function getNotifications(){ try{ return JSON.parse(localStorage.getItem(NOTIF_KEY)||'[]'); }catch(e){ return []; } }
function saveNotifications(n){ localStorage.setItem(NOTIF_KEY, JSON.stringify(n)); }

function showNotifications(){
  const notifs = getNotifications();
  const unread = notifs.filter(n=>!n.leido);
  if(!notifs.length){ alert('📭 No hay notificaciones del administrador'); return; }
  let msg = '📢 NOTIFICACIONES:\n\n';
  notifs.slice(-5).reverse().forEach(n=>{ msg += `• ${n.msg}\n  (${n.ts})\n\n`; });
  alert(msg);
  // Mark all read
  const updated = notifs.map(n=>({...n, leido:true}));
  saveNotifications(updated);
  updateNotifBadge();
}

function updateNotifBadge(){
  const unread = getNotifications().filter(n=>!n.leido).length;
  document.getElementById('notif-icon').textContent = unread > 0 ? '🔔' : '🔕';
  const bnNotif = document.getElementById('bn-notif');
  if(unread>0) bnNotif.style.color='var(--amb)';
  else bnNotif.style.color='';
}

// Render notifications in home
function renderHomeNotifs(){
  const container = document.getElementById('notif-container');
  if(!container) return;
  const notifs = getNotifications().filter(n=>!n.leido).slice(-3);
  container.innerHTML = notifs.map(n=>`
    <div class="notif-banner" id="nb-${n.id}">
      <div class="nb-icon">📢</div>
      <div class="nb-text">
        <div>${n.msg}</div>
        <div class="nb-time">${n.ts}</div>
      </div>
      <button class="notif-close" onclick="dismissNotif(${n.id})">✕</button>
    </div>`).join('');
}

function dismissNotif(id){
  const el = document.getElementById('nb-'+id);
  if(el) el.remove();
  const notifs = getNotifications().map(n=>n.id===id?{...n,leido:true}:n);
  saveNotifications(notifs);
  updateNotifBadge();
}

// ── SYNC HTML DATA (called by admin from Telegram) ──
// The bot generates a JSON file; admin can paste it here
function syncFromJSON(jsonStr){
  try{
    const newData = JSON.parse(jsonStr);
    if(!Array.isArray(newData)) throw new Error('Invalid');
    localStorage.setItem('tb_data_sync', JSON.stringify(newData));
    alert('✅ Datos sincronizados. Recarga la página.');
  }catch(e){
    alert('❌ JSON inválido: '+e.message);
  }
}

// ── SCREEN NAV ──
let screenHistory = [];
function showScreen(id){
  const currentUser = getSession(); if(!currentUser && id!=='screen-login'){
    if(typeof showToast==='function') showToast('🔒 Sin acceso','Regístrate o inicia sesión','e',3000);
    return;
  }
  document.querySelectorAll('.screen').forEach(function(s){
    s.classList.remove('active');
    s.style.display='none';
  });
  var s=document.getElementById(id);
  if(s){s.style.display='block';s.classList.add('active');}
}
function goBack(){
  if(screenHistory.length>0) showScreen(screenHistory.pop());
  else showScreen('screen-home');
}
function setNav(id){
  document.querySelectorAll('.bn-item').forEach(b=>b.classList.remove('active'));
  document.getElementById(id)?.classList.add('active');
}

// ── SEARCH ──
let selectedPerson = null;

function onSearch(val){
  const sug = document.getElementById('suggestions');
  if(val.length < 2){ sug.style.display='none'; return; }
  const q = val.toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
  const matches = allNames.filter(n=>{
    const norm = n.normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    return norm.includes(q);
  }).slice(0,6);
  if(!matches.length){ sug.style.display='none'; return; }
  sug.innerHTML = matches.map(n=>`
    <div class="sug-item" onclick="selectPerson('${n.replace(/'/g,"\'")}')" >
      <div class="sug-avatar">${initials(n)}</div>
      <span>${n}</span>
    </div>`).join('');
  sug.style.display='block';
}

function doSearch(){
  const val = document.getElementById('search-input').value.trim().toUpperCase();
  const match = allNames.find(n=>n.includes(val));
  if(match) selectPerson(match);
}

function selectPerson(name){
  selectedPerson = name;
  document.getElementById('search-input').value = name;
  document.getElementById('suggestions').style.display = 'none';
  screenHistory.push('screen-home');
  showDatePicker(name);
}

function showDatePicker(name){
  const rows = getPersonData(name);
  const total = rows.reduce((s,r)=>s+r.horas,0);
  document.getElementById('dp-title').textContent = name.split(' ').slice(0,2).join(' ');
  document.getElementById('person-banner').innerHTML = `
    <div class="pb-avatar">${initials(name)}</div>
    <div>
      <div class="pb-name">${name}</div>
      <div class="pb-meta">${rows.length} días · ${total.toFixed(1)}h totales esta maya</div>
    </div>`;
  const today = TODAY;
  document.getElementById('days-grid').innerHTML = rows.map(r=>`
    <div class="day-card${r.fecha===today?' today-card':''}" onclick="showTurno('${name.replace(/'/g,"\'")}','${r.fecha}')">
      ${r.fecha===today?'<div class="today-pill">HOY</div>':''}
      <div class="dc-dow">${dowLabel(r.fecha)}</div>
      <div class="dc-date">${shortDate(r.fecha)}</div>
      <div class="dc-entry">${r.entrada12||'—'}</div>
    </div>`).join('');
  // Semana view
  document.getElementById('dp-semana').innerHTML = `
    <div class="week-table">
      <div class="wt-head"><span>Semana completa · ${name.split(' ')[0]}</span><span style="font-family:var(--mono);font-size:11px;color:var(--grn)">${total.toFixed(1)}h</span></div>
      ${rows.map(r=>`
        <div class="wt-row">
          <div class="wt-day-col">
            <div class="wt-dow">${dowLabel(r.fecha)}</div>
            <div class="wt-date">${shortDate(r.fecha)}</div>
          </div>
          <div class="wt-content">
            <div class="wt-times">
              <span class="time-pill entrada">▶ ${r.entrada12||'—'}</span>
              <span class="time-pill salida">■ ${r.salida12||'—'}</span>
            </div>
            <div class="wt-horas">${r.horas}h
              <span class="hbar"><span class="hbar-fill${r.horas<7.5?' warn':''}" style="width:${Math.min(100,(r.horas/8)*100)}%"></span></span>
            </div>
          </div>
        </div>`).join('')}
    </div>`;
  showScreen('screen-datepicker');
  setNav('');
}

function switchDpTab(el, target){
  el.closest('.tabs').querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['dp-dias','dp-semana'].forEach(id=>{
    document.getElementById(id).classList.toggle('section-hidden', id!==target);
  });
}

function showTurno(name, fecha){
  screenHistory.push('screen-datepicker');
  const rows = getPersonData(name);
  const r = getByDate(name, fecha);
  document.getElementById('tc-day-nav').innerHTML = rows.map(row=>
    `<div class="tc-daysel${row.fecha===fecha?' active':''}" onclick="showTurno('${name.replace(/'/g,"\'")}','${row.fecha}')">
      ${dowLabel(row.fecha)} ${shortDate(row.fecha)}
    </div>`).join('');
  const compBreak1 = DATA.filter(x=>x.fecha===fecha&&x.nombre!==name&&x.break1===r.break1&&r.break1).map(x=>x.nombre.split(' ').slice(0,2).join(' '));
  const compBreak2 = DATA.filter(x=>x.fecha===fecha&&x.nombre!==name&&x.break2===r.break2&&r.break2).map(x=>x.nombre.split(' ').slice(0,2).join(' '));
  const compAlm = DATA.filter(x=>x.fecha===fecha&&x.nombre!==name&&x.almuerzo===r.almuerzo&&r.almuerzo).map(x=>x.nombre.split(' ').slice(0,2).join(' '));
  const compEntrada = DATA.filter(x=>x.fecha===fecha&&x.nombre!==name&&x.entrada===r.entrada&&r.entrada).map(x=>x.nombre.split(' ').slice(0,2).join(' '));
  const pct = Math.min(100, Math.round((r.horas/8)*100));
  const warn = r.horas < 7.5;
  document.getElementById('turno-content').innerHTML = `
    <div class="plantilla">
      <div class="pl-head">
        <div class="pl-head-top">
          <div class="pl-head-top-left">
            <div class="pl-robot">🤖</div>
          </div>
          <div style="display:flex;align-items:center;gap:10px">
            <img src="${CLARO_IMG}" class="pl-claro-logo" alt="Claro">
            <div class="pl-title">TURNOBOT<br>MAYA 11–16 MAYO</div>
          </div>
        </div>
        <div class="pl-name">${name}</div>
        <div class="pl-fecha">📅 ${dowLabel(fecha)}, ${fecha}</div>
        <div class="pl-estado-badge">🟢 ACTIVO</div>
      </div>
      <div class="pl-body">
        <div class="pl-section">
          <div class="pl-section-title">⏱ Cronograma del día</div>
          <div class="pl-timeline">
            <div class="pl-tl-item">
              <div class="pl-tl-dot dot-grn"></div>
              <div class="pl-tl-label">🟢 Entrada</div>
              <div class="pl-tl-time" style="color:var(--grn)">${r.entrada12||'—'}</div>
            </div>
            ${r.break1_12?`<div class="pl-tl-item">
              <div class="pl-tl-dot dot-amb"></div>
              <div class="pl-tl-label">☕ Break 1</div>
              <div class="pl-tl-time" style="color:var(--amb)">${r.break1_12} → ${r.break1_fin12} <span style="font-size:10px;color:var(--tx3)">(15 min)</span></div>
            </div>`:''}
            ${r.alm12?`<div class="pl-tl-item">
              <div class="pl-tl-dot dot-blue"></div>
              <div class="pl-tl-label">🍽 Almuerzo</div>
              <div class="pl-tl-time" style="color:var(--acc)">${r.alm12} → ${r.alm_fin12} <span style="font-size:10px;color:var(--tx3)">(60 min)</span></div>
            </div>`:''}
            ${r.break2_12?`<div class="pl-tl-item">
              <div class="pl-tl-dot dot-pur"></div>
              <div class="pl-tl-label">🍵 Break 2</div>
              <div class="pl-tl-time" style="color:var(--pur)">${r.break2_12} → ${r.break2_fin12} <span style="font-size:10px;color:var(--tx3)">(15 min)</span></div>
            </div>`:''}
            <div class="pl-tl-item">
              <div class="pl-tl-dot dot-red"></div>
              <div class="pl-tl-label">🔴 Salida</div>
              <div class="pl-tl-time" style="color:var(--red)">${r.salida12||'—'}</div>
            </div>
          </div>
        </div>
        <div class="pl-section">
          <div class="pl-section-title">📊 Horas netas</div>
          <div class="horas-box${warn?' warn':''}">
            <div>
              <div class="hb-left">Horas netas trabajadas</div>
              <div class="hb-prog"><div class="hb-fill${warn?' warn':''}" style="width:${pct}%"></div></div>
            </div>
            <div>
              <div class="hb-val${warn?' warn':''}">${r.horas}h</div>
            </div>
          </div>
        </div>
        <div class="pl-section">
          <div class="pl-section-title">📋 Detalles</div>
          <div class="pl-row"><span class="pl-key">🚻 Baño</span><span class="pl-val blue">12 min c/supervisor</span></div>
          <div class="pl-row"><span class="pl-key">📍 Estado</span><span class="pl-val green">ACTIVO</span></div>
          <div class="pl-row"><span class="pl-key">📅 Maya</span><span class="pl-val">11/05/2026 — 16/05/2026</span></div>
        </div>
        <div class="pl-section">
          <div class="pl-section-title">🤝 Compañeros de bloque</div>
          <div class="comp-section">
            ${compEntrada.length?`<div class="comp-group"><div class="comp-group-title">▶️ Entrada ${r.entrada12} (${compEntrada.length})</div><div class="comp-chips">${compEntrada.map(n=>`<span class="comp-chip">${n}</span>`).join('')}</div></div>`:''}
            ${compBreak1.length?`<div class="comp-group"><div class="comp-group-title">☕ Break 1 ${r.break1_12} (${compBreak1.length})</div><div class="comp-chips">${compBreak1.map(n=>`<span class="comp-chip">${n}</span>`).join('')}</div></div>`:''}
            ${compAlm.length?`<div class="comp-group"><div class="comp-group-title">🍽 Almuerzo ${r.alm12} (${compAlm.length})</div><div class="comp-chips">${compAlm.map(n=>`<span class="comp-chip">${n}</span>`).join('')}</div></div>`:''}
            ${compBreak2.length?`<div class="comp-group"><div class="comp-group-title">🍵 Break 2 ${r.break2_12} (${compBreak2.length})</div><div class="comp-chips">${compBreak2.map(n=>`<span class="comp-chip">${n}</span>`).join('')}</div></div>`:''}
            ${!compEntrada.length&&!compBreak1.length&&!compAlm.length&&!compBreak2.length?'<div style="color:var(--tx3);font-size:12px;text-align:center;padding:10px">Sin compañeros en el mismo bloque</div>':''}
          </div>
        </div>
      </div>
    </div>`;
  showScreen('screen-turno');
  setNav('');
}

// ── INIT ──
function initHome(){
  // Agregar botón cambiar contraseña al header si no existe
  if(!document.getElementById('btn-cambiar-pass')){
    const hdr = document.getElementById('header-right');
    if(hdr){ const btn = document.createElement('button'); btn.id='btn-cambiar-pass'; btn.onclick=abrirCambiarPass;
      btn.style.cssText='background:none;border:1px solid var(--pur);color:var(--pur);border-radius:5px;font-size:9px;cursor:pointer;padding:2px 6px;margin-top:4px;font-family:var(--mono)';
      btn.textContent='🔑 Cambiar pass'; hdr.appendChild(document.createElement('br')); hdr.appendChild(btn); }
  }
  const session = getSession();
  if(!session){ showScreen('screen-login'); return; }
  document.getElementById('stat-hoy').textContent = todayData.length;
  document.getElementById('header-right').innerHTML = `
    Maya <span>11/05/2026 — 16/05/2026</span><br>
    <span id="live-time">—</span>&nbsp;
    <span style="color:var(--tx3);font-size:9px">👤 ${session.nombre.split(' ')[0]}</span>`;
  renderHomeNotifs();
  updateNotifBadge();
  // Auto-select own person
  const own = allNames.find(n=>n===session.nombre);
  if(own){
    document.getElementById('search-input').value = own;
  }
  showScreen('screen-home');
}

function updateClock(){
  const n=new Date();
  const el = document.getElementById('live-time');
  if(el) el.textContent = n.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
updateClock(); setInterval(updateClock,1000);

document.addEventListener('click', e=>{
  if(!document.getElementById('search-wrap').contains(e.target))
    document.getElementById('suggestions').style.display='none';
});

document.getElementById('login-pass').addEventListener('keypress',e=>{ if(e.key==='Enter') doLogin(); });
document.getElementById('login-nombre').addEventListener('keypress',e=>{ if(e.key==='Enter') doLogin(); });

// ── STARTUP ──
setTimeout(()=>{
  document.getElementById('loading-overlay').style.display='none';
  const session = getSession();
  mostrarSplash(session);
  if(session){ initHome(); }
  else { showScreen('screen-login'); }
}, 800);
</script>
</body>
</html>