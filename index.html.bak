<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<link rel="manifest" href="/milleapp/manifest.json">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>TurnoBot · Maya 11/05/2026 — 16/05/2026</title>
<style>
:root {
  --bg:#0d0f14; --sur:#151820; --sur2:#1c2030; --bor:#252b3b;
  --acc:#3b82f6; --grn:#10b981; --amb:#f59e0b; --red:#ef4444; --pur:#8b5cf6;
  --tx:#e2e8f0; --tx2:#94a3b8; --tx3:#4b5563;
  --mono:'Courier New',monospace; --sans:system-ui,sans-serif;
  --r:10px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:var(--sans);font-size:14px;min-height:100vh}

/* ANIMATIONS */
@keyframes fi{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}

/* HEADER */
header{background:var(--sur);border-bottom:1px solid var(--bor);padding:0 16px;display:flex;align-items:center;justify-content:space-between;height:54px;position:sticky;top:0;z-index:200}
.logo{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:13px;font-weight:700;color:var(--acc)}
.logo-box{width:30px;height:30px;border-radius:7px;overflow:hidden;display:flex;align-items:center;justify-content:center}
.logo-box img{width:100%;height:100%;object-fit:cover;border-radius:7px;animation:pulse 2s infinite;box-shadow:0 0 12px rgba(255,106,0,.7),0 0 24px rgba(255,165,0,.4)}
.hdr-right{font-family:var(--mono);font-size:10px;color:var(--tx2);text-align:right;line-height:1.7}
.hdr-right span{color:var(--grn)}

/* SCREEN SYSTEM */
.screen{display:none;min-height:calc(100vh - 54px);padding:20px 16px}
.screen.active{display:block;animation:fi .25s ease}

/* LOGIN SCREEN */
.login-wrap{max-width:380px;margin:40px auto 0;animation:slideUp .4s ease}
.login-logo{text-align:center;margin-bottom:28px}
.login-logo img{width:80px;height:80px;border-radius:50%;border:2px solid var(--bor);animation:pulse 3s infinite}
.login-title{font-size:20px;font-weight:700;text-align:center;margin-bottom:6px}
.login-sub{color:var(--tx2);font-size:12px;text-align:center;margin-bottom:24px}
.login-card{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:24px;animation:slideUp .5s ease}
.field{margin-bottom:16px}
.field label{display:block;font-size:11px;color:var(--tx2);margin-bottom:6px;font-family:var(--mono);letter-spacing:1px;text-transform:uppercase}
.field input{width:100%;background:var(--sur2);border:1px solid var(--bor);border-radius:7px;padding:11px 14px;color:var(--tx);font-size:14px;outline:none;transition:border-color .2s}
.field input:focus{border-color:var(--acc)}
.btn-primary{width:100%;background:var(--acc);color:#fff;border:none;border-radius:8px;padding:12px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;margin-top:4px}
.btn-primary:hover{background:#2563eb;transform:translateY(-1px)}
.btn-primary:active{transform:translateY(0)}
.login-error{color:var(--red);font-size:12px;text-align:center;margin-top:10px;display:none}
.login-toggle{text-align:center;margin-top:14px;font-size:12px;color:var(--tx2)}
.login-toggle a{color:var(--acc);cursor:pointer;text-decoration:underline}

/* NOTIFICATION BANNER */
.notif-banner{background:linear-gradient(135deg,rgba(245,158,11,.15),rgba(245,158,11,.05));border:1px solid rgba(245,158,11,.3);border-radius:var(--r);padding:12px 14px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;animation:slideUp .3s ease}
.notif-banner .nb-icon{font-size:18px;flex-shrink:0;margin-top:1px}
.notif-banner .nb-text{font-size:12px;color:var(--tx);flex:1}
.notif-banner .nb-time{font-size:10px;color:var(--tx3);margin-top:3px}
.notif-close{background:none;border:none;color:var(--tx3);cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px}
.notif-close:hover{color:var(--tx)}

/* HOME */
.home-hero{text-align:center;padding:30px 20px 24px;animation:slideUp .35s ease}
.home-icon{margin-bottom:12px}
.home-icon img{width:64px;height:64px;border-radius:50%;border:2px solid var(--bor)}
.home-title{font-size:22px;font-weight:700;margin-bottom:6px}
.home-sub{color:var(--tx2);font-size:13px;margin-bottom:8px}
.maya-badge{display:inline-block;background:rgba(59,130,246,.15);color:var(--acc);border:1px solid rgba(59,130,246,.3);border-radius:20px;padding:4px 14px;font-family:var(--mono);font-size:11px;margin-bottom:24px}

/* SEARCH BOX */
.search-wrap{max-width:420px;margin:0 auto 20px;position:relative}
.search-input{width:100%;background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:13px 46px 13px 16px;color:var(--tx);font-size:15px;font-family:var(--sans);outline:none;transition:border-color .2s,box-shadow .2s}
.search-input:focus{border-color:var(--acc);box-shadow:0 0 0 3px rgba(59,130,246,.1)}
.search-input::placeholder{color:var(--tx3)}
.search-btn{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:var(--acc);border:none;color:#fff;width:32px;height:32px;border-radius:6px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;transition:background .15s}
.search-btn:hover{background:#2563eb}
.suggestions{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);overflow:hidden;z-index:100;max-height:220px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,.4);animation:fadeIn .15s ease}
.sug-item{padding:10px 14px;cursor:pointer;font-size:13px;transition:background .1s;display:flex;align-items:center;gap:8px}
.sug-item:hover{background:var(--sur2)}
.sug-item:not(:last-child){border-bottom:1px solid var(--bor)}
.sug-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--pur));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;color:#fff}

/* QUICK STATS HOME */
.quick-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;max-width:420px;margin:0 auto}
.qs-card{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:14px;text-align:center;animation:slideUp .4s ease}
.qs-val{font-family:var(--mono);font-size:20px;font-weight:700}
.qs-lbl{font-size:11px;color:var(--tx2);margin-top:3px}
.qs-val.blue{color:var(--acc)} .qs-val.green{color:var(--grn)} .qs-val.amber{color:var(--amb)}

/* DATE PICKER */
.dp-header{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.back-btn{background:var(--sur2);border:1px solid var(--bor);color:var(--tx2);padding:7px 12px;border-radius:7px;cursor:pointer;font-size:12px;display:flex;align-items:center;gap:5px;transition:all .15s}
.back-btn:hover{border-color:var(--acc);color:var(--acc)}
.dp-title{font-size:16px;font-weight:700}
.dp-sub{font-size:12px;color:var(--tx2);margin-top:2px}
.person-banner{background:linear-gradient(135deg,rgba(59,130,246,.15),rgba(99,102,241,.1));border:1px solid rgba(59,130,246,.25);border-radius:var(--r);padding:14px 16px;display:flex;align-items:center;gap:12px;margin-bottom:20px;animation:slideUp .3s ease}
.pb-avatar{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--pur));display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;flex-shrink:0}
.pb-name{font-size:14px;font-weight:700}
.pb-meta{font-size:11px;color:var(--tx2);margin-top:2px}
.days-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px}
.day-card{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:14px 10px;text-align:center;cursor:pointer;transition:all .2s;position:relative;animation:slideUp .3s ease}
.day-card:hover{border-color:var(--acc);transform:translateY(-2px);box-shadow:0 4px 16px rgba(59,130,246,.2)}
.day-card.today-card{border-color:var(--grn);box-shadow:0 0 0 1px rgba(16,185,129,.2)}
.dc-dow{font-size:10px;color:var(--tx3);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.dc-date{font-family:var(--mono);font-size:16px;font-weight:700;margin-bottom:6px}
.dc-entry{font-size:11px;color:var(--acc);font-family:var(--mono)}
.today-pill{position:absolute;top:-8px;left:50%;transform:translateX(-50%);background:var(--grn);color:#fff;font-size:9px;padding:1px 7px;border-radius:10px;font-weight:700;white-space:nowrap}

/* TURNO CARD */
.tc-wrapper{max-width:480px;margin:0 auto}
.tc-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.tc-nav-left{display:flex;gap:8px;flex-wrap:wrap}
.tc-daysel{background:var(--sur2);border:1px solid var(--bor);color:var(--tx2);padding:6px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-family:var(--mono);transition:all .15s}
.tc-daysel:hover,.tc-daysel.active{border-color:var(--acc);color:var(--acc);background:rgba(59,130,246,.1)}
.plantilla{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.3);animation:slideUp .3s ease}
.pl-head{background:linear-gradient(135deg,#1e3a5f,#1a2942);padding:16px;border-bottom:1px solid var(--bor)}
.pl-head-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.pl-head-top-left{display:flex;align-items:center;gap:10px}
.pl-robot{font-size:24px}
.pl-claro-logo{height:28px;width:auto;display:block}
.pl-title{font-size:11px;font-family:var(--mono);color:var(--acc);letter-spacing:1px;text-align:right}
.pl-name{font-size:16px;font-weight:700;margin-bottom:2px}
.pl-fecha{font-family:var(--mono);font-size:11px;color:var(--tx2)}
.pl-estado-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(16,185,129,.15);color:var(--grn);border:1px solid rgba(16,185,129,.25);border-radius:5px;padding:3px 8px;font-size:11px;font-weight:600;margin-top:6px}
.pl-body{padding:14px 16px}
.pl-section{margin-bottom:14px}
.pl-section-title{font-size:9px;font-family:var(--mono);color:var(--tx3);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.pl-section-title::after{content:'';flex:1;height:1px;background:var(--bor)}
.pl-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.pl-row:last-child{border-bottom:none}
.pl-key{font-size:12px;color:var(--tx2);display:flex;align-items:center;gap:7px}
.pl-val{font-family:var(--mono);font-size:12px;font-weight:600}
.pl-val.green{color:var(--grn)} .pl-val.red{color:var(--red)} .pl-val.amber{color:var(--amb)} .pl-val.blue{color:var(--acc)}
.pl-timeline{position:relative;padding-left:18px;margin-top:8px}
.pl-timeline::before{content:'';position:absolute;left:5px;top:4px;bottom:4px;width:1px;background:var(--bor)}
.pl-tl-item{position:relative;margin-bottom:8px;padding-left:6px;animation:slideUp .3s ease}
.pl-tl-dot{position:absolute;left:-13px;top:4px;width:7px;height:7px;border-radius:50%;border:2px solid var(--bg)}
.dot-grn{background:var(--grn)} .dot-amb{background:var(--amb)} .dot-red{background:var(--red)} .dot-pur{background:var(--pur)} .dot-blue{background:var(--acc)}
.pl-tl-label{font-size:11px;color:var(--tx2);margin-bottom:1px}
.pl-tl-time{font-family:var(--mono);font-size:13px;font-weight:700}
.horas-box{background:rgba(16,185,129,.07);border:1px solid rgba(16,185,129,.2);border-radius:8px;padding:12px;display:flex;align-items:center;justify-content:space-between;margin-top:12px}
.horas-box.warn{background:rgba(245,158,11,.07);border-color:rgba(245,158,11,.2)}
.hb-left{font-size:11px;color:var(--tx2)}
.hb-val{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--grn)}
.hb-val.warn{color:var(--amb)}
.hb-prog{height:4px;background:var(--bor);border-radius:2px;margin-top:6px;overflow:hidden;width:120px}
.hb-fill{height:100%;border-radius:2px;background:var(--grn);transition:width .4s}
.hb-fill.warn{background:var(--amb)}
.comp-section{margin-top:14px}
.comp-group{background:var(--sur2);border-radius:8px;padding:10px 12px;margin-bottom:8px;animation:slideUp .3s ease}
.comp-group-title{font-size:11px;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:5px}
.comp-chips{display:flex;flex-wrap:wrap;gap:5px}
.comp-chip{background:var(--sur);border:1px solid var(--bor);padding:3px 8px;border-radius:4px;font-size:11px;color:var(--tx2)}

/* TABS */
.tabs{display:flex;gap:4px;background:var(--sur2);border-radius:8px;padding:3px;margin-bottom:16px;width:fit-content}
.tab{padding:6px 12px;border-radius:5px;cursor:pointer;font-size:12px;color:var(--tx2);transition:all .15s}
.tab.active{background:var(--sur);color:var(--tx);box-shadow:0 1px 4px rgba(0,0,0,.3)}

/* NAV BOTTOM */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(--sur);border-top:1px solid var(--bor);display:flex;z-index:150;padding-bottom:env(safe-area-inset-bottom,0)}
.bn-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:8px 4px;cursor:pointer;transition:color .15s;color:var(--tx3);font-size:10px;gap:3px;border:none;background:none}
.bn-item.active{color:var(--acc)}
.bn-item .bn-icon{font-size:20px;line-height:1}
body{padding-bottom:70px}

/* UTIL */
.section-hidden{display:none}
.mt8{margin-top:8px}
.chip-fecha{background:var(--sur2);border:1px solid var(--bor);border-radius:5px;padding:2px 8px;font-family:var(--mono);font-size:10px;color:var(--tx2)}
.week-table{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);overflow:hidden}
.wt-head{padding:12px 14px;border-bottom:1px solid var(--bor);font-size:13px;font-weight:600;display:flex;justify-content:space-between;align-items:center}
.wt-row{display:flex;align-items:stretch;border-bottom:1px solid var(--bor)}
.wt-row:last-child{border-bottom:none}
.wt-day-col{width:70px;flex-shrink:0;padding:10px;background:var(--sur2);display:flex;flex-direction:column;justify-content:center;border-right:1px solid var(--bor)}
.wt-dow{font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:1px}
.wt-date{font-family:var(--mono);font-size:12px;font-weight:700;margin-top:2px}
.wt-content{flex:1;padding:10px 12px}
.wt-times{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:4px}
.time-pill{background:var(--sur2);border:1px solid var(--bor);padding:2px 7px;border-radius:4px;font-family:var(--mono);font-size:11px;color:var(--tx2)}
.time-pill.entrada{border-color:rgba(16,185,129,.4);color:var(--grn)}
.time-pill.salida{border-color:rgba(239,68,68,.3);color:var(--red)}
.wt-horas{font-family:var(--mono);font-size:11px;color:var(--tx2)}
.hbar{display:inline-block;width:50px;height:3px;background:var(--bor);border-radius:2px;margin:0 4px;vertical-align:middle;overflow:hidden}
.hbar-fill{height:100%;border-radius:2px;background:var(--grn)}
.hbar-fill.warn{background:var(--amb)}

/* USER AVATAR TOP */
.user-info-top{display:flex;align-items:center;gap:6px}
.user-avatar-sm{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--acc),var(--pur));display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff}
.logout-btn{background:none;border:1px solid var(--bor);color:var(--tx3);padding:3px 8px;border-radius:5px;font-size:10px;cursor:pointer;transition:all .15s;font-family:var(--mono)}
.logout-btn:hover{border-color:var(--red);color:var(--red)}

/* LOADING */
.loading-overlay{position:fixed;inset:0;background:rgba(13,15,20,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:999;animation:fadeIn .2s ease}
.loading-spin{width:36px;height:36px;border:3px solid var(--bor);border-top-color:var(--acc);border-radius:50%;animation:spin .7s linear infinite;margin-bottom:12px}
.loading-text{font-size:13px;color:var(--tx2)}

@media(max-width:360px){.days-grid{grid-template-columns:repeat(2,1fr)}}

/* SPLASH */
#splash-screen{position:fixed;inset:0;z-index:1100;background:linear-gradient(135deg,#0d0f14 60%,#1a1040 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity .7s ease}
#splash-screen.hidden{opacity:0;pointer-events:none}
.splash-avatar{width:90px;height:90px;border-radius:50%;border:3px solid var(--pur);object-fit:cover;box-shadow:0 0 24px rgba(139,92,246,.5);animation:pulse 2s infinite}
.splash-avatar-default{width:90px;height:90px;border-radius:50%;border:3px solid var(--pur);background:linear-gradient(135deg,var(--acc),var(--pur));display:flex;align-items:center;justify-content:center;font-size:36px;box-shadow:0 0 24px rgba(139,92,246,.5);animation:pulse 2s infinite}
.splash-greeting{font-size:22px;font-weight:700;text-align:center;color:var(--tx)}
.splash-name{font-size:16px;color:var(--pur);font-weight:600;text-align:center}
.splash-loader{display:flex;gap:6px;margin-top:8px}
.splash-dot{width:8px;height:8px;border-radius:50%;background:var(--pur);animation:splashDot 1.2s infinite}
.splash-dot:nth-child(2){animation-delay:.2s}.splash-dot:nth-child(3){animation-delay:.4s}
@keyframes splashDot{0%,80%,100%{transform:scale(.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.splash-footer{font-size:10px;color:var(--tx3);text-align:center;position:absolute;bottom:20px;width:100%}
.fire-name{background:linear-gradient(90deg,#ff6a00,#ffd700,#ff4500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:700;animation:fireAnim 2s linear infinite;background-size:200%}
@keyframes fireAnim{0%{background-position:0%}100%{background-position:200%}}
/* MODALES CONTRASEÑA */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:600;display:flex;align-items:center;justify-content:center;padding:16px;animation:fadeIn .2s ease}
.modal-box{background:var(--sur);border:1px solid var(--bor);border-radius:var(--r);padding:24px;max-width:360px;width:100%;animation:slideUp .3s ease}
.modal-title{font-size:15px;font-weight:700;margin-bottom:16px}
.modal-close-btn{float:right;background:none;border:none;color:var(--tx3);cursor:pointer;font-size:18px;line-height:1}
.btn-sec{width:100%;background:var(--sur2);color:var(--tx);border:1px solid var(--bor);border-radius:8px;padding:10px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;margin-top:8px}
.btn-sec:hover{border-color:var(--pur);color:var(--pur)}
.modal-msg{font-size:12px;text-align:center;margin-top:8px;display:none;border-radius:6px;padding:8px}
/* FOTO REGISTRO */
.foto-upload-wrap{display:flex;flex-direction:column;align-items:center;gap:6px;margin-bottom:4px}
.foto-preview{width:72px;height:72px;border-radius:50%;border:2px dashed var(--bor);background:var(--sur2);display:flex;align-items:center;justify-content:center;font-size:28px;cursor:pointer;overflow:hidden;transition:border-color .2s}
.foto-preview:hover{border-color:var(--acc)}
.foto-preview img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.foto-lbl{font-size:11px;color:var(--tx3)}
</style>
</head>
<body>

<!-- SPLASH BIENVENIDA -->
<div id="splash-screen">
  <div id="splash-av" class="splash-avatar-default">🤖</div>
  <div class="splash-greeting" id="splash-greeting">¡Bienvenido!</div>
  <div class="splash-name" id="splash-uname"></div>
  <div class="splash-loader"><div class="splash-dot"></div><div class="splash-dot"></div><div class="splash-dot"></div></div>
  <div class="splash-footer">App ligera desarrollada por <span class="fire-name">🔥 Moisés Rojas 🔥</span></div>
</div>

<!-- LOADING OVERLAY -->
<div class="loading-overlay" id="loading-overlay">
  <div class="loading-spin"></div>
  <div class="loading-text">Cargando...</div>
</div>

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-box"><img src="data:image/jpeg;base64," alt="MPC"></div>
    TURNOBOT
  </div>
  <div id="header-right" class="hdr-right">
    Maya <span>11/05/2026 — 16/05/2026</span><br><span id="live-time">—</span>
  </div>
</header>

<!-- ══════════════════ SCREEN: LOGIN ══════════════════ -->
<div class="screen" id="screen-login">
  <div class="login-wrap">
    <div class="login-logo">
      <img src="data:image/jpeg;base64," alt="Millennium Phone Center">
    </div>
    <div class="login-title">Portal de Turnos</div>
    <div class="login-sub">Millennium Phone Center · Claro</div>
    <div class="login-card" id="login-card">
      <div class="field">
        <label>Nombre completo</label>
        <input type="text" id="login-nombre" placeholder="Como aparece en la maya..." autocomplete="name">
      </div>
      <div class="field">
        <label>Contraseña</label>
        <input type="password" id="login-pass" placeholder="••••••••" autocomplete="current-password">
      </div>
      <button class="btn-primary" onclick="doLogin()">🔓 Entrar</button>
      <div class="login-error" id="login-error">❌ Nombre no encontrado o contraseña incorrecta</div>
      <button class="btn-primary" onclick="loginMoi()" style="background:var(--pur);margin-top:8px">🔑 Acceso Moisés (Admin)</button>
  <div class="login-toggle">¿No tienes contraseña? <a onclick="showRegister()">Regístrate aquí</a></div>
  <div class="login-toggle" style="margin-top:6px"><a onclick="showRecover()" style="color:var(--tx3)">🔑 Olvidé mi contraseña</a></div>
    </div>
    <div class="login-card" id="register-card" style="display:none;margin-top:12px">
      <div style="font-size:13px;font-weight:600;margin-bottom:14px">📝 Crear cuenta</div>
      <div class="foto-upload-wrap">
        <div class="foto-preview" id="reg-foto-prev" onclick="document.getElementById('reg-foto-input').click()">📷</div>
        <div class="foto-lbl">Foto obligatoria (toca para subir)</div>
        <input type="file" id="reg-foto-input" accept="image/*" style="display:none" onchange="previewRegFoto(this)">
      </div>
      <div class="field">
        <label>Tu nombre (como en la maya)</label>
        <input type="text" id="reg-nombre" placeholder="APELLIDO NOMBRE...">
      </div>
      <div class="field">
        <label>Nombre completo real</label>
        <input type="text" id="reg-nombre-completo" placeholder="Nombre y apellidos completos">
      </div>
      <div class="field">
        <label>Celular</label>
        <input type="tel" id="reg-celular" placeholder="Ej: 3001234567">
      </div>
      <div class="field">
        <label>Correo electrónico</label>
        <input type="email" id="reg-correo" placeholder="Para recuperar tu contraseña">
      </div>
      <div class="field">
        <label>Elige una contraseña</label>
        <input type="password" id="reg-pass" placeholder="Mínimo 4 caracteres">
      </div>
      <div class="field">
        <label>Confirmar contraseña</label>
        <input type="password" id="reg-pass2" placeholder="Repite la contraseña">
      </div>
      <button class="btn-primary" onclick="doRegister()">✅ Registrarme</button>
      <div class="login-error" id="reg-error"></div>
      <div class="login-toggle"><a onclick="showLogin()">← Volver al inicio de sesión</a></div>
    </div>
  </div>
</div>

<!-- MODAL: CAMBIAR CONTRASEÑA -->
<div class="modal-overlay" id="modal-cambiar-pass" style="display:none">
  <div class="modal-box">
    <button class="modal-close-btn" onclick="document.getElementById('modal-cambiar-pass').style.display='none'">✕</button>
    <div class="modal-title">🔐 Cambiar contraseña</div>
    <div class="field"><label>Contraseña actual</label><input type="password" id="cp-actual" placeholder="••••••••"></div>
    <div class="field"><label>Nueva contraseña</label><input type="password" id="cp-nueva" placeholder="Mínimo 4 caracteres"></div>
    <div class="field"><label>Confirmar nueva</label><input type="password" id="cp-nueva2" placeholder="Repite la nueva contraseña"></div>
    <button class="btn-primary" onclick="doCambiarPass()">💾 Guardar nueva contraseña</button>
    <div class="modal-msg" id="cp-msg"></div>
  </div>
</div>

<!-- MODAL: RECUPERAR CONTRASEÑA -->
<div class="modal-overlay" id="modal-recover" style="display:none">
  <div class="modal-box">
    <button class="modal-close-btn" onclick="document.getElementById('modal-recover').style.display='none'">✕</button>
    <div class="modal-title">📧 Recuperar contraseña</div>
    <div id="recover-step1">
      <div class="field"><label>Tu nombre (como en la maya)</label><input type="text" id="rec-nombre" placeholder="APELLIDO NOMBRE..."></div>
      <button class="btn-primary" onclick="doSolicitarToken()">📨 Enviar token a mi correo</button>
      <div class="modal-msg" id="rec-msg1"></div>
    </div>
    <div id="recover-step2" style="display:none">
      <p style="font-size:12px;color:var(--tx2);margin-bottom:12px">Ingresa el token de 6 dígitos que recibiste en tu correo:</p>
      <div class="field"><label>Token</label><input type="text" id="rec-token" placeholder="123456" maxlength="6" inputmode="numeric"></div>
      <div class="field"><label>Nueva contraseña</label><input type="password" id="rec-nueva" placeholder="Mínimo 4 caracteres"></div>
      <button class="btn-primary" onclick="doResetPass()">✅ Restablecer contraseña</button>
      <div class="modal-msg" id="rec-msg2"></div>
    </div>
  </div>
</div>

<!-- ══════════════════ SCREEN: HOME ══════════════════ -->
<div class="screen" id="screen-home">
  <div id="notif-container"></div>
  <div class="home-hero">
    <div class="home-icon"><img src="data:image/jpeg;base64," alt="MPC"></div>
    <div class="home-title">Consulta tu turno</div>
    <div class="home-sub">Maya del 11 al 16 de Mayo · <b>38 asesores</b></div>
    <div class="maya-badge">📅 11/05/2026 — 16/05/2026</div>
    <div class="search-wrap" id="search-wrap">
      <input class="search-input" id="search-input" type="text" placeholder="🔍 Escribe tu nombre..." autocomplete="off" oninput="onSearch(this.value)">
      <button class="search-btn" onclick="doSearch()">→</button>
      <div class="suggestions" id="suggestions" style="display:none"></div>
    </div>
    <div class="quick-stats">
      <div class="qs-card"><div class="qs-val blue">38</div><div class="qs-lbl">Asesores</div></div>
      <div class="qs-card"><div class="qs-val green" id="stat-hoy">—</div><div class="qs-lbl">Activos hoy</div></div>
      <div class="qs-card"><div class="qs-val amber">6</div><div class="qs-lbl">Días maya</div></div>
    </div>
  </div>
</div>

<!-- ══════════════════ SCREEN: DATE PICKER ══════════════════ -->
<div class="screen" id="screen-datepicker">
  <div class="dp-header">
    <button class="back-btn" onclick="goBack()">← Volver</button>
    <div>
      <div class="dp-title" id="dp-title">Selecciona un día</div>
      <div class="dp-sub">Toca el día que quieres consultar</div>
    </div>
  </div>
  <div class="person-banner" id="person-banner"></div>
  <div class="days-grid" id="days-grid"></div>
  <div class="tabs">
    <div class="tab active" onclick="switchDpTab(this,'dp-dias')">📅 Por día</div>
    <div class="tab" onclick="switchDpTab(this,'dp-semana')">📊 Semana completa</div>
  </div>
  <div id="dp-dias"></div>
  <div id="dp-semana" class="section-hidden"></div>
</div>

<!-- ══════════════════ SCREEN: TURNO DETAIL ══════════════════ -->
<div class="screen" id="screen-turno">
  <div class="tc-nav">
    <button class="back-btn" onclick="goBack()">← Volver</button>
    <div class="tc-nav-left" id="tc-day-nav"></div>
  </div>
  <div class="tc-wrapper" id="turno-content"></div>
</div>

<!-- BOTTOM NAV (solo asesor) -->
<nav class="bottom-nav">
  <button class="bn-item active" id="bn-home" onclick="showScreen('screen-home');setNav('bn-home')">
    <span class="bn-icon">🏠</span>Inicio
  </button>
  <button class="bn-item" id="bn-buscar" onclick="showScreen('screen-home');setNav('bn-buscar');document.getElementById('search-input').focus()">
    <span class="bn-icon">🔍</span>Buscar
  </button>
  <button class="bn-item" id="bn-notif" onclick="showNotifications()">
    <span class="bn-icon" id="notif-icon">🔔</span>Avisos
  </button>
  <button class="bn-item" id="bn-salir" onclick="doLogout()">
    <span class="bn-icon">🚪</span>Salir
  </button>
</nav>

